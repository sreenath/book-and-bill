{
  "name": "book-and-bill",
  "version": "1.0.0",
  "description": "AI Agent built with Google ADK (TypeScript)",
  "type": "module",
  "main": "app/agent.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && npx @google/adk-devtools web -h localhost dist/agent.js",
    "cli": "tsc && npx @google/adk-devtools run dist/agent.js --log_level warn",
    "test": "vitest run",
    "test:unit": "vitest run app",
    "test:integration": "vitest run tests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "@types/pdfkit": "^0.17.6",
    "dotenv": "^17.2.3",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@google/adk": "^0.3.0",
    "@google/adk-devtools": "^0.3.0",
    "pdfkit": "^0.19.1",
    "tslib": "^2.8.1",
    "zod": "^4.2.1"
  }
}